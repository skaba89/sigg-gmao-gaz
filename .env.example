# ============================================================
# SIGG GMAO Platform - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://sigg_admin:sigg_secure_2024@localhost:5432/sigg_gmao?schema=public
POSTGRES_DB=sigg_gmao
POSTGRES_USER=sigg_admin
POSTGRES_PASSWORD=sigg_secure_2024
POSTGRES_PORT=5432

# ---- Authentication - JWT ----
# IMPORTANT: Change this in production! Use a strong random string (min 32 chars)
JWT_SECRET=sigg-gmao-jwt-secret-change-in-production-2024
JWT_EXPIRES_IN=24h

# ---- Seed Endpoint Protection ----
# Required to access GET /api/seed (SUPER_ADMIN + this key)
SEED_KEY=sigg-seed-key-change-in-production-2024

# ---- Application ----
APP_PORT=3000
NODE_ENV=production
